{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "ignore": ["./apps/synapse-playground/src/components/ui/**", "utils/**"],
  "exclude": ["namespaceMembers"],
  "ignoreWorkspaces": ["examples/script-tag"],
  "ignoreBinaries": ["wrangler"],
  "ignoreDependencies": [
    "@types/*",
    "assert",
    "mocha",
    "wrangler",
    "typedoc",
    "typedoc-plugin-mdn-links",
    "typedoc-plugin-missing-exports"
  ],
  "msw": {
    "entry": ["test/mocks/mockServiceWorker.js"]
  },
  "workspaces": {
    "docs": {
      "ignoreDependencies": ["@filoz/synapse-sdk", "@filoz/synapse-react", "@tanstack/react-query", "wagmi"],
      "ignoreFiles": ["src/custom.css"]
    },
    "packages/synapse-core": {
      "ignoreFiles": ["wagmi.config.ts"]
    }
  }
}
